# Neovim plugins (managed by lazy.nvim)
nvim/plugin/
nvim/.config/nvim/plugin/

# Tmux plugins (managed by TPM)
tmux/.config/tmux/plugins/

# Shell script local data
# Ignore everything in .local/ except scripts/
shellscript/.local/**
!shellscript/.local/scripts/
!shellscript/.local/scripts/**

# macOS
.DS_Store
._.DS_Store
.Spotlight-V100
.Trashes
__MACOSX/

# Editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Temporary files
*.tmp
*.temp
*.log
*.bak
*.cache

# Node modules (if any)
node_modules/

# Cache directories
.cache/
**/.cache/

# Lazy nvim lock file (often regenerated)
**/lazy-lock.json

# Mason packages (LSP servers - managed by nvim, not dotfiles)
shellscript/.local/share/nvim/mason/

# Kiro - ignore sessions, secrets, and transient state
kiro/.config/kiro/sessions/
kiro/.config/kiro/settings/mcp.json
kiro/.config/kiro/settings/feed_state.json
kiro/.config/kiro/settings/survey_state.json
kiro/.config/kiro/.cli_bash_history
kiro/.kiro/sessions/
kiro/.kiro/settings/
kiro/.kiro/.cli_bash_history

# Pi agent - ignore auth and sessions
pi/.config/pi/agent/auth.json
pi/.config/pi/agent/sessions/

# OpenCode - ignore auth files
shellscript/.local/share/opencode/auth.json

# Build artifacts
*.o
*.so
*.dylib
*.exe
*.dll

# Log files
*.log

# Ignore .git in submodules (they are part of the submodule)
# But do not ignore .gitmodules and .gitignore
!.gitmodules
!!.gitignore

# Ignore OS-specific files
Thumbs.db
Desktop.ini

# Secrets & credentials - NEVER commit any API key or access token
*.env
.env
.env.*
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.pub
*auth.json
auth.json
mcp.json
**/mcp.json
*credentials*
*.credentials
*secret*
.secrets
*.token
*token.json
*.key.json
*apikey*
*api_key*
*access_token*